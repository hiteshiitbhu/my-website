---
import "../styles/global.css";

const profile = {
  name: "Hitesh Bansal",
  role: "Electrical Engineer, IIT (BHU) Varanasi",
  location: "Muktsar, Punjab, India",
  statement:
    "Early-career engineer blending electrical systems thinking with software, data, and automation to build practical products.",
  email: "hitesh.bansal.engineer@gmail.com",
};

const navLinks = [
  { label: "Home", href: "#home" },
  { label: "About", href: "#about" },
  { label: "Skills", href: "#skills" },
  { label: "Projects", href: "#projects" },
  { label: "Roadmap", href: "#roadmap" },
  { label: "Contact", href: "#contact" },
];

const highlights = [
  "Open to internship and full-time opportunities",
  "Focus: Embedded + software-driven engineering",
  "Building a portfolio that proves execution",
];

const skills = [
  {
    domain: "Electrical Core",
    items: ["Power Systems", "Control Systems", "Circuit Design", "Signal Processing"],
  },
  {
    domain: "Programming",
    items: ["Python", "C/C++", "JavaScript", "SQL"],
  },
  {
    domain: "Engineering Tools",
    items: ["MATLAB", "Simulink", "LTspice", "Git", "Linux"],
  },
  {
    domain: "Tech Direction",
    items: ["IoT Prototyping", "Data Analysis", "Web Engineering", "Automation Scripts"],
  },
];

const projects = [
  {
    title: "Smart Transformer Health Monitor",
    type: "IoT + Analytics",
    summary:
      "Built a sensor-based prototype to monitor temperature, current, and vibration with real-time alert thresholds.",
    impact: "Reduced fault detection time in simulations by 38%.",
    stack: ["ESP32", "Python", "MQTT", "InfluxDB", "Grafana"],
    status: "Prototype complete",
    link: "https://github.com/hitesh-bansal-sample/smart-transformer-monitor",
  },
  {
    title: "Load Forecasting Mini Suite",
    type: "Energy Data",
    summary:
      "Created a lightweight forecasting workflow for daily load prediction and dashboard interpretation.",
    impact: "Improved baseline forecast accuracy by 21% on sample utility data.",
    stack: ["Python", "Pandas", "scikit-learn", "Plotly"],
    status: "Iteration 2 in progress",
    link: "https://github.com/hitesh-bansal-sample/load-forecast-suite",
  },
  {
    title: "Campus Power Audit Toolkit",
    type: "Automation",
    summary:
      "Developed scripts and templates to standardize meter readings, anomaly detection, and reporting.",
    impact: "Saved roughly 6 hours/week in repetitive reporting tasks.",
    stack: ["Python", "Excel API", "Jupyter", "Seaborn"],
    status: "Actively used",
    link: "https://github.com/hitesh-bansal-sample/power-audit-toolkit",
  },
  {
    title: "Personal Career Command Center",
    type: "Web Product",
    summary:
      "Designed a portfolio dashboard to track learning goals, applications, and project outcomes.",
    impact: "Increased weekly consistency for learning and applications.",
    stack: ["Astro", "TypeScript", "CSS", "Netlify"],
    status: "MVP shipped",
    link: "https://github.com/hitesh-bansal-sample/career-command-center",
  },
];

const roadmap = [
  {
    period: "Now",
    goal: "Strengthen software depth",
    detail: "Ship one engineering-focused project every month with proper documentation.",
  },
  {
    period: "Next 3 Months",
    goal: "Hands-on internships and collaborations",
    detail: "Target roles in energy-tech, embedded systems, and data-driven engineering teams.",
  },
  {
    period: "Next 6-12 Months",
    goal: "Transition into product-building engineer",
    detail: "Combine domain knowledge and software to solve reliability and efficiency problems.",
  },
];

const socials = [
  { label: "LinkedIn", value: "linkedin.com/in/hitesh-bansal-sample", href: "https://linkedin.com/in/hitesh-bansal-sample" },
  { label: "GitHub", value: "github.com/hitesh-bansal-sample", href: "https://github.com/hitesh-bansal-sample" },
  { label: "X", value: "x.com/hitesh_bansal_sample", href: "https://x.com/hitesh_bansal_sample" },
  { label: "LeetCode", value: "leetcode.com/hitesh-bansal-sample", href: "https://leetcode.com/hitesh-bansal-sample" },
  { label: "Codeforces", value: "codeforces.com/profile/hitesh_bansal_sample", href: "https://codeforces.com/profile/hitesh_bansal_sample" },
  { label: "CodeChef", value: "codechef.com/users/hitesh_bansal_sample", href: "https://www.codechef.com/users/hitesh_bansal_sample" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Portfolio of Hitesh Bansal - Electrical Engineer from IIT BHU, exploring software, automation, and energy-tech opportunities."
    />
    <meta property="og:title" content="Hitesh Bansal | Electrical Engineer + Tech Builder" />
    <meta
      property="og:description"
      content="A bold portfolio showcasing projects, skills, and career direction in engineering + technology."
    />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>Hitesh Bansal | Electrical Engineer + Tech Builder</title>
  </head>
  <body>
    <a class="skip-link" href="#home">Skip to content</a>

    <header class="site-header reveal">
      <p class="logo">HB//SIGNAL</p>
      <nav aria-label="Main navigation">
        <ul>
          {
            navLinks.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))
          }
        </ul>
      </nav>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Switch to dark mode">
        Dark
      </button>
    </header>

    <main>
      <section id="home" class="hero section reveal">
        <p class="eyebrow">Engineering + Software Portfolio</p>
        <h1>
          {profile.name}
          <span>{profile.role}</span>
        </h1>
        <p class="lead">{profile.statement}</p>
        <p class="location">Based in {profile.location}</p>

        <div class="hero-actions">
          <a class="button button-primary" href="#projects">See Projects</a>
          <a class="button button-secondary" href={`mailto:${profile.email}`}>Reach by Email</a>
        </div>

        <ul class="highlight-list">
          {
            highlights.map((item, index) => (
              <li class="reveal" style={`--stagger:${index + 1};`}>{item}</li>
            ))
          }
        </ul>
      </section>

      <section id="about" class="section reveal">
        <div class="section-title-wrap">
          <p class="section-index">01</p>
          <h2>About</h2>
        </div>
        <p>
          I am an Electrical Engineer from IIT (BHU) with a strong interest in building systems that are both
          technically correct and practical to deploy. My core strength is translating engineering constraints into
          software-first solutions that are measurable and scalable.
        </p>
        <p>
          I am currently focused on opportunities where I can contribute to real products in energy-tech,
          automation, or embedded software while continuously improving my coding depth.
        </p>
      </section>

      <section id="skills" class="section reveal">
        <div class="section-title-wrap">
          <p class="section-index">02</p>
          <h2>Skill Matrix</h2>
        </div>
        <div class="skill-grid">
          {
            skills.map((group) => (
              <article class="skill-block reveal">
                <h3>{group.domain}</h3>
                <ul>
                  {group.items.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section id="projects" class="section reveal">
        <div class="section-title-wrap">
          <p class="section-index">03</p>
          <h2>Projects</h2>
        </div>
        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card reveal">
                <p class="project-type">{project.type}</p>
                <h3>{project.title}</h3>
                <p>{project.summary}</p>
                <p class="impact">{project.impact}</p>
                <ul class="stack-list">
                  {project.stack.map((tech) => <li>{tech}</li>)}
                </ul>
                <div class="project-foot">
                  <span>{project.status}</span>
                  <a href={project.link} target="_blank" rel="noreferrer">Open</a>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section id="roadmap" class="section reveal">
        <div class="section-title-wrap">
          <p class="section-index">04</p>
          <h2>Career Roadmap</h2>
        </div>
        <div class="timeline">
          {
            roadmap.map((item) => (
              <article class="timeline-item reveal">
                <p class="period">{item.period}</p>
                <h3>{item.goal}</h3>
                <p>{item.detail}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section id="contact" class="section reveal">
        <div class="section-title-wrap">
          <p class="section-index">05</p>
          <h2>Contact</h2>
        </div>
        <p class="contact-intro">
          I am actively looking for opportunities where electrical engineering meets software.
          Let us connect.
        </p>

        <div class="contact-grid">
          <article>
            <p class="contact-label">Email</p>
            <a href={`mailto:${profile.email}`}>{profile.email}</a>
          </article>
          {
            socials.map((item) => (
              <article>
                <p class="contact-label">{item.label}</p>
                <a href={item.href} target="_blank" rel="noreferrer">{item.value}</a>
              </article>
            ))
          }
        </div>
      </section>
    </main>

    <footer class="site-footer reveal">
      <p>Designed and built for Hitesh Bansal.</p>
      <p>Sample content - replace links and metrics with real profile data.</p>
      <p><span id="year"></span> | Muktsar to wherever the next build is.</p>
    </footer>

    <script is:inline>
      const root = document.documentElement;
      const themeToggle = document.getElementById("theme-toggle");
      const header = document.querySelector(".site-header");
      const yearNode = document.getElementById("year");

      const applyTheme = (theme) => {
        root.dataset.theme = theme;
        if (themeToggle) {
          const nextTheme = theme === "dark" ? "light" : "dark";
          themeToggle.textContent = nextTheme === "dark" ? "Dark" : "Light";
          themeToggle.setAttribute("aria-label", `Switch to ${nextTheme} mode`);
        }
      };

      const storedTheme = localStorage.getItem("hb-theme");
      const initialTheme = storedTheme === "dark" ? "dark" : "light";
      applyTheme(initialTheme);

      themeToggle?.addEventListener("click", () => {
        const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
        applyTheme(nextTheme);
        localStorage.setItem("hb-theme", nextTheme);
      });

      if (yearNode) {
        yearNode.textContent = String(new Date().getFullYear());
      }

      const revealElements = Array.from(document.querySelectorAll(".reveal"));
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2, rootMargin: "0px 0px -8% 0px" }
      );

      revealElements.forEach((item, index) => {
        item.style.setProperty("--delay", `${Math.min(index * 70, 560)}ms`);
        observer.observe(item);
      });

      const mobileQuery = window.matchMedia("(max-width: 900px)");
      let lastY = window.scrollY;
      let ticking = false;

      const updateHeaderVisibility = () => {
        if (!header || !mobileQuery.matches) {
          ticking = false;
          return;
        }

        const currentY = window.scrollY;
        const delta = currentY - lastY;

        if (currentY <= 20) {
          header.classList.remove("nav-hidden");
          lastY = currentY;
          ticking = false;
          return;
        }

        if (Math.abs(delta) < 6) {
          ticking = false;
          return;
        }

        if (delta > 0 && currentY > 64) {
          header.classList.add("nav-hidden");
        } else {
          header.classList.remove("nav-hidden");
        }

        lastY = currentY;
        ticking = false;
      };

      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          window.requestAnimationFrame(updateHeaderVisibility);
        }
      };

      window.addEventListener("scroll", onScroll, { passive: true });

      mobileQuery.addEventListener("change", () => {
        if (!header) {
          return;
        }
        lastY = window.scrollY;
        header.classList.remove("nav-hidden");
      });

      header?.addEventListener("focusin", () => {
        header.classList.remove("nav-hidden");
      });
    </script>
  </body>
</html>
